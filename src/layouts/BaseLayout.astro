---
import Nav from '../components/Nav.astro';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
	title: string;
	backLink?: { href: string; label: string };
}

const { title, backLink } = Astro.props;
const buildDate = new Date().toLocaleDateString('sv-SE');
---

<html lang="zh-Hant" class="no-js">
	<head>
		<meta charset="utf-8" />
		<script>
			document.documentElement.classList.replace('no-js', 'js');
		</script>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700&family=Noto+Serif+TC:wght@400;600;700&display=swap"
			rel="stylesheet"
		/>
		<meta property="og:title" content={title} />
		<meta property="og:description" content="統計背景，正朝資料科學邁進。" />
		<meta property="og:image" content="https://xup6m4jo6222.github.io/images/og-card.png" />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary_large_image" />
		<ClientRouter />
		<title>{title}</title>
	</head>
	<body>
		<Nav backLink={backLink} />
		<main>
			<slot />
		</main>
		<footer>
			<div class="footer-inner">
				<span>&copy; 2026 林郁為</span>
				<span>最後更新 {buildDate}</span>
			</div>
		</footer>
		<script>
			const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			const hasIO = 'IntersectionObserver' in window;

			// 進場淡入（每次 page-load 對尚未顯示的元素重跑）
			function initReveal() {
				const targets = document.querySelectorAll('[data-reveal]:not(.is-visible)');
				if (reduceMotion || !hasIO) {
					targets.forEach((el) => el.classList.add('is-visible'));
					return;
				}
				const observer = new IntersectionObserver(
					(entries) => {
						for (const entry of entries) {
							if (entry.isIntersecting) {
								entry.target.classList.add('is-visible');
								observer.unobserve(entry.target);
							}
						}
					},
					{ threshold: 0.15 },
				);
				targets.forEach((el) => observer.observe(el));
			}

			// 內文圖片載入後淡入（無 JS 時預設可見）
			function initImageFade() {
				document.querySelectorAll('.content img').forEach((img) => {
					if (img.complete) return;
					img.classList.add('is-loading');
					const done = () => img.classList.remove('is-loading');
					img.addEventListener('load', done, { once: true });
					img.addEventListener('error', done, { once: true });
				});
			}

			// 軸線即進度：.tl 左軸線隨捲動填色 + 導覽列紀元進度小字
			let progressCleanup = null;
			function initProgress() {
				if (progressCleanup) {
					progressCleanup();
					progressCleanup = null;
				}
				const tl = document.querySelector('.tl');
				const label = document.querySelector('.nav-progress');
				if (!tl) {
					if (label) {
						label.classList.remove('is-visible');
						label.textContent = '';
					}
					return;
				}

				let fill = tl.querySelector('.tl-fill');
				if (!fill) {
					fill = document.createElement('div');
					fill.className = 'tl-fill';
					tl.appendChild(fill);
				}

				const eras = Array.from(tl.querySelectorAll('.tl-era'));
				let ticking = false;
				const update = () => {
					ticking = false;
					const mid = window.scrollY + window.innerHeight / 2;
					const tlTop = tl.getBoundingClientRect().top + window.scrollY;
					const tlH = tl.offsetHeight;
					// 視窗中線在 .tl 內走過的比例 → 填色高度
					const travelled = Math.max(0, Math.min(tlH, mid - tlTop));
					fill.style.height = travelled + 'px';

					if (label) {
						const doc = document.documentElement;
						const max = doc.scrollHeight - doc.clientHeight;
						const pct = max > 0 ? Math.round((doc.scrollTop / max) * 100) : 0;
						// 視窗中線目前所在紀元
						let eraName = '';
						for (const era of eras) {
							const eraTop = era.getBoundingClientRect().top + window.scrollY;
							if (eraTop <= mid) {
								const h = era.querySelector('h2');
								eraName = h ? h.textContent || '' : '';
							}
						}
						label.textContent = eraName ? eraName + ' · ' + pct + '%' : pct + '%';
						const show = window.scrollY > window.innerHeight;
						label.classList.toggle('is-visible', show);
					}
				};
				const onScroll = () => {
					if (!ticking) {
						ticking = true;
						requestAnimationFrame(update);
					}
				};
				window.addEventListener('scroll', onScroll, { passive: true });
				window.addEventListener('resize', update);
				progressCleanup = () => {
					window.removeEventListener('scroll', onScroll);
					window.removeEventListener('resize', update);
				};
				update();
			}

			document.addEventListener('astro:page-load', () => {
				initReveal();
				initImageFade();
				initProgress();
			});
		</script>
	</body>
</html>
