---
import BaseLayout from '../layouts/BaseLayout.astro';

const entryLinks = [
	{ label: 'GitHub', href: 'https://github.com/xup6m4jo6222' },
	{ label: 'Email', href: 'mailto:xup6m4jo6222@gmail.com' },
];
---

<BaseLayout title="林郁為">
	<section class="hero">
		<h1 data-reveal>林郁為</h1>
		<p data-reveal style="transition-delay: 380ms">統計背景，正朝資料科學邁進。</p>
	</section>
	<section class="entry-links" data-reveal style="transition-delay: 380ms">
		{entryLinks.map((link) => <a href={link.href}>{link.label}</a>)}
	</section>
</BaseLayout>
