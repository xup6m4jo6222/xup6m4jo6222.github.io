---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');

const categories = [
	{ key: 'stats', label: '統計分析' },
	{ key: 'ai', label: 'AI 實作' },
] as const;
---

<BaseLayout title="Projects | 林郁為">
	<p class="intro">這裡放的都是我自己做的小專案</p>
	{
		categories.map((category) => {
			const items = allProjects.filter((project) => project.data.category === category.key);
			return (
				<section class="category">
					<h2>{category.label}</h2>
					<div class="cards">
						{items.map((item) => {
							const slug = item.id.split('/').slice(1).join('/');
							return (
								<a class="card" href={`/projects/${category.key}/${slug}/`}>
									<h3>{item.data.title}</h3>
									<p>{item.data.summary}</p>
								</a>
							);
						})}
					</div>
				</section>
			);
		})
	}
</BaseLayout>
